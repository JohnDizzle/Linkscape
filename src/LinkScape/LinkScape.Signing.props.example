<Project>
  <!--
    Copy this file to LinkScape.Signing.props and keep it out of source control.
    Use it only on your local machine or in CI when you are ready to sign MSIX packages.
  -->
  <PropertyGroup>
    <Project>
      <PropertyGroup>
        <AppxPackageSigningEnabled>True</AppxPackageSigningEnabled>
        <PackageCertificateThumbprint>YOUR_CERTIFICATE_THUMBPRINT</PackageCertificateThumbprint>
        <GenerateTemporaryStoreCertificate>False</GenerateTemporaryStoreCertificate>
      </PropertyGroup>
    </Project>
  </PropertyGroup>
</Project>
